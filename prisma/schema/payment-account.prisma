model PaymentAccount {
    id         String   @id @default(uuid(7)) @db.Uuid
    merchantId String   @db.Uuid
    merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

    providerType PaymentProviderType
    providerName String

    accountName String

    accountNumber String

    // Only needed for Banks
    branchName    String?
    routingNumber String?

    // Stripe specific fields
    stripeCustomerId        String? @db.VarChar(255)
    stripePaymentMethodId   String? @db.VarChar(255)
    stripePaymentMethodType String? @db.VarChar(100)
    cardBrand               String? @db.VarChar(100)
    cardLast4               String? @db.VarChar(4)
    cardExpMonth            Int?
    cardExpYear             Int?
    billingEmail            String? @db.VarChar(320)

    isDefault Boolean @default(false)
    isActive  Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    payouts Payout[]

    @@index([merchantId], name: "idx_payment_account_merchant_id")
    @@index([stripeCustomerId], name: "idx_payment_account_stripe_customer_id")
    @@index([stripePaymentMethodId], name: "idx_payment_account_stripe_payment_method_id")
    @@map("payment_accounts")
}
