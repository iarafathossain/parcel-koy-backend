model Area {
    id       String  @id @default(uuid(7)) @db.Uuid
    name     String
    slug     String  @unique
    isActive Boolean @default(true)

    zoneId String @db.Uuid
    zone   Zone   @relation(fields: [zoneId], references: [id])

    hubID String? @db.Uuid
    hub   Hub?    @relation("HubCoverageArea", fields: [hubID], references: [id])

    originParcels      Parcel[]   @relation("ParcelOriginArea")
    destinationParcels Parcel[]   @relation("ParcelDestinationArea")
    merchants          Merchant[] @relation("MerchantOriginArea")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([slug], name: "idx_area_slug")
    @@map("areas")
}
