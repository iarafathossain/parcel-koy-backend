model Pricing {
    id String @id @default(uuid(7)) @db.Uuid

    originalZoneId String @db.Uuid
    originalZone   Zone   @relation("OriginalZone", fields: [originalZoneId], references: [id])

    destinationZoneId String @db.Uuid
    destinationZone   Zone   @relation("DestinationZone", fields: [destinationZoneId], references: [id])

    categoryId String   @db.Uuid
    category   Category @relation(fields: [categoryId], references: [id])

    speedId String @db.Uuid
    speed   Speed  @relation(fields: [speedId], references: [id])

    pickupMethodId String @db.Uuid
    pickupMethod   Method @relation("PricingPickupMethod", fields: [pickupMethodId], references: [id])

    deliveryMethodId String @db.Uuid
    deliveryMethod   Method @relation("PricingDeliveryMethod", fields: [deliveryMethodId], references: [id])

    // Financial & Weight constraints
    minWeight Float
    maxWeight Float
    price     Decimal @db.Decimal(10, 2)
    isActive  Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // prevent duplicate pricing rules for the same zone, category, speed, and method combination
    @@unique([originalZoneId, destinationZoneId, categoryId, speedId, pickupMethodId, deliveryMethodId], name: "unique_pricing_rule")
    @@index([originalZoneId], name: "idx_pricing_original_zone_id")
    @@index([destinationZoneId], name: "idx_pricing_destination_zone_id")
    @@map("pricing")
}
