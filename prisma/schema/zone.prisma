model Zone {
    id            String  @id @default(uuid(7)) @db.Uuid
    name          String
    slug          String  @unique
    isActive      Boolean @default(true)
    isInsideDhaka Boolean

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    areas              Area[]
    pricingOrigin      Pricing[] @relation("OriginalZone")
    pricingDestination Pricing[] @relation("DestinationZone")

    @@map("zones")
}
