model Payout {
    id     String       @id @default(uuid(7)) @db.Uuid
    amount Decimal      @db.Decimal(10, 2)
    status PayoutStatus @default(PENDING)

    // Simplified: We only need the Stripe Transfer ID and raw response
    transactionId      String? @db.VarChar(300) // Will hold tr_...
    paymentGatewayData Json?
    adminNote          String? @db.Text

    // Relations
    merchantId String   @db.Uuid
    merchant   Merchant @relation("MerchantPayouts", fields: [merchantId], references: [id])

    paymentAccountId String         @db.Uuid
    paymentAccount   PaymentAccount @relation(fields: [paymentAccountId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([merchantId], name: "idx_payout_merchant_id")
    @@index([status], name: "idx_payout_status")
    @@map("payouts")
}
