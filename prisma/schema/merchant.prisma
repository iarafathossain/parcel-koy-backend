model Merchant {
    id            String @id @default(uuid(7)) @db.Uuid
    userId        String @unique @db.Uuid
    user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    businessName  String @db.Text
    pickupAddress String @db.Text
    originAreaId  String @db.Uuid
    originArea    Area   @relation("MerchantOriginArea", fields: [originAreaId], references: [id])
    averageRating Float  @default(0.0)

    balance     Decimal @default(0.00) @db.Decimal(10, 2)
    creditLimit Decimal @default(0.00) @db.Decimal(10, 2)

    parcels Parcel[]
    payouts Payout[] @relation("MerchantPayouts")

    @@index([userId], name: "idx_merchant_user_id")
    @@map("merchants")
}
