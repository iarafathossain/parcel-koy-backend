model PaymentAccount {
    id         String   @id @default(uuid(7)) @db.Uuid
    merchantId String   @db.Uuid
    merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

    providerType PaymentProviderType @default(STRIPE)

    // The only crucial piece of data we need to store
    stripeConnectAccountId String @unique @db.VarChar(255) // e.g., acct_1N...

    isDefault Boolean @default(false)
    isActive  Boolean @default(false) // Becomes true ONLY after Stripe onboarding is complete

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    payouts Payout[]

    @@index([merchantId], name: "idx_payment_account_merchant_id")
    @@map("payment_accounts")
}
