model Hub {
    id            String @id @default(uuid(7)) @db.Uuid
    name          String @unique
    slug          String @unique
    address       String
    contactNumber String

    managerId String? @db.Uuid
    manager   Admin?  @relation("HubManager", fields: [managerId], references: [id])

    riders Rider[] @relation("HubRiders")

    coverageAreas Area[] @relation("HubCoverageArea")

    // Hub routing operations
    originParcels      Parcel[]      @relation("OriginHub")
    destinationParcels Parcel[]      @relation("DestinationHub")
    trackingLogs       TrackingLog[]

    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
    cashCollections CashCollection[]

    @@index([name], name: "idx_hub_name")
    @@map("hubs")
}
