model Parcel {
    id         String @id @default(uuid(7)) @db.Uuid
    trackingId String @unique // e.g., PKY-2026-8F21A

    // Relations
    merchantId String   @db.Uuid
    merchant   Merchant @relation(fields: [merchantId], references: [id])

    categoryId String   @db.Uuid
    category   Category @relation(fields: [categoryId], references: [id])

    destinationAreaId String @db.Uuid
    destinationArea   Area   @relation("ParcelDestinationArea", fields: [destinationAreaId], references: [id])

    originAreaId String @db.Uuid
    originArea   Area   @relation("ParcelOriginArea", fields: [originAreaId], references: [id])

    speedId String @db.Uuid
    speed   Speed  @relation(fields: [speedId], references: [id])

    methodId String @db.Uuid
    method   Method @relation(fields: [methodId], references: [id])

    // Routing & Assignment
    pickupRiderId String? @db.Uuid
    pickupRider   Rider?  @relation("PickupRider", fields: [pickupRiderId], references: [id])

    deliveryRiderId String? @db.Uuid
    deliveryRider   Rider?  @relation("DeliveryRider", fields: [deliveryRiderId], references: [id])

    originHubId String? @db.Uuid
    originHub   Hub?    @relation("OriginHub", fields: [originHubId], references: [id])

    destinationHubId String? @db.Uuid
    destinationHub   Hub?    @relation("DestinationHub", fields: [destinationHubId], references: [id])

    // Parcel Details
    status         ParcelStatus @default(REQUESTED)
    declaredWeight Float
    actualWeight   Float? // Updated after pickup
    isFragile      Boolean      @default(false)

    cancellationReason String?   @db.Text
    cancelledAt        DateTime?

    cancelledById String? @db.Uuid
    cancelledBy   User?   @relation("ParcelCancelledBy", fields: [cancelledById], references: [id])

    pickupFailedReason   String? @db.Text
    deliveryFailedReason String? @db.Text

    // Addresses & Contacts
    pickupAddress         String
    deliveryAddress       String
    receiverName          String
    receiverContactNumber String

    // Financials
    codAmount      Decimal @db.Decimal(10, 2) // Cash to collect from receiver
    deliveryCharge Decimal @db.Decimal(10, 2) // Calculated fee at time of creation

    // Security
    deliveryOtp            String?   @db.VarChar(6)
    deliveryOtpGeneratedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    trackingLogs TrackingLog[]
    notes        Note[]

    @@index([trackingId], name: "idx_parcel_tracking_id")
    @@index([merchantId], name: "idx_parcel_merchant_id")
    @@map("parcels")
}
