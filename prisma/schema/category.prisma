model Category {
    id         String  @id @default(uuid(7)) @db.Uuid
    name       String
    slug       String  @unique
    baseWeight Float
    baseFee    Decimal @default(0.00) @db.Decimal(10, 2)
    isActive   Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    parcels Parcel[]
    pricing Pricing[]

    @@map("categories")
}
